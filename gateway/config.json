{
  "adapters": [
    { "type": "simulator" },
    {
      "type": "modbus",
      "id": "plc1",
      "label": "Conveyor PLC (Modbus TCP)",
      "host": "127.0.0.1",
      "port": 5020,
      "unitId": 1,
      "pollMs": 100,
      "tags": [
        { "name": "motorRun", "label": "Motor run command", "kind": "coil", "address": 0, "writable": true },
        { "name": "running", "label": "Motor running", "kind": "discrete", "address": 0 },
        { "name": "speedSetpoint", "label": "Speed setpoint", "kind": "holding", "address": 0, "scale": 0.1, "unit": "%", "writable": true },
        { "name": "beltSpeed", "label": "Belt speed", "kind": "input", "address": 0, "scale": 0.1, "unit": "%" },
        { "name": "motorCurrent", "label": "Motor current", "kind": "input", "address": 1, "scale": 0.01, "unit": "A" }
      ]
    },
    {
      "type": "opcua",
      "id": "mixer1",
      "label": "Mixer skid (OPC UA)",
      "endpoint": "opc.tcp://127.0.0.1:4850/UA/MixerSim",
      "publishingIntervalMs": 100,
      "tags": [
        { "name": "agitatorOn", "label": "Agitator on", "nodeId": "ns=1;s=Mixer.AgitatorOn", "dataType": "boolean", "writable": true },
        { "name": "agitatorSpeed", "label": "Agitator speed", "nodeId": "ns=1;s=Mixer.AgitatorSpeed", "dataType": "number", "unit": "rpm", "writable": true },
        { "name": "tankLevel", "label": "Tank level", "nodeId": "ns=1;s=Mixer.TankLevel", "dataType": "number", "unit": "%" },
        { "name": "motorTemp", "label": "Motor temperature", "nodeId": "ns=1;s=Mixer.MotorTemp", "dataType": "number", "unit": "degC" },
        { "name": "batchCount", "label": "Batch count", "nodeId": "ns=1;s=Mixer.BatchCount", "dataType": "number" }
      ]
    },
    {
      "type": "mqtt",
      "id": "esp1",
      "label": "ESP32 fan node (MQTT)",
      "url": "mqtt://127.0.0.1:1883",
      "availabilityTopic": "automation-sim/fan/status",
      "tags": [
        { "name": "temperature", "label": "Room temperature", "topic": "automation-sim/env/temperature", "dataType": "number", "jsonPath": "value", "unit": "degC" },
        { "name": "humidity", "label": "Room humidity", "topic": "automation-sim/env/humidity", "dataType": "number", "jsonPath": "value", "unit": "%" },
        { "name": "fanOn", "label": "Fan on", "topic": "automation-sim/fan/state/on", "commandTopic": "automation-sim/fan/cmd/on", "dataType": "boolean", "writable": true },
        { "name": "fanSpeed", "label": "Fan speed setpoint", "topic": "automation-sim/fan/state/speed", "commandTopic": "automation-sim/fan/cmd/speed", "dataType": "number", "unit": "%", "writable": true },
        { "name": "fanRpm", "label": "Fan RPM", "topic": "automation-sim/fan/state/rpm", "dataType": "number", "unit": "rpm" }
      ]
    },
    {
      "type": "tiaweb",
      "id": "tia",
      "label": "TIA Web PLC",
      "url": "http://127.0.0.1:8000",
      "pollMs": 100
    },
    {
      "type": "memory",
      "id": "virtual",
      "label": "Virtual tags (soft wiring)",
      "tags": [
        { "name": "b1", "label": "Virtual bool 1", "dataType": "boolean" },
        { "name": "b2", "label": "Virtual bool 2", "dataType": "boolean" },
        { "name": "b3", "label": "Virtual bool 3", "dataType": "boolean" },
        { "name": "b4", "label": "Virtual bool 4", "dataType": "boolean" },
        { "name": "n1", "label": "Virtual number 1", "dataType": "number" },
        { "name": "n2", "label": "Virtual number 2", "dataType": "number" }
      ]
    },
    {
      "type": "conveyor",
      "id": "conv",
      "label": "Conveyor line (machine model)",
      "beltLength": 4,
      "eyeAt": 3,
      "maxSpeed": 1.2,
      "minSpeed": 0.4,
      "autoFeedS": 3,
      "partSlots": 4
    },
    {
      "type": "press",
      "id": "press",
      "label": "Hydraulic press (machine model)",
      "strokeS": 4,
      "defaultTarget": 150
    },
    {
      "type": "mixer",
      "id": "mixer",
      "label": "Mixer skid (machine model)",
      "batchS": 8,
      "overTempC": 50
    },
    {
      "type": "s7",
      "id": "press1",
      "label": "Hydraulic press (S7)",
      "host": "127.0.0.1",
      "port": 9102,
      "rack": 0,
      "slot": 1,
      "pollMs": 100,
      "tags": [
        { "name": "ramPosition", "label": "Ram position", "address": "DB1,REAL0", "dataType": "number", "unit": "mm" },
        { "name": "pressure", "label": "Hydraulic pressure", "address": "DB1,REAL4", "dataType": "number", "unit": "bar" },
        { "name": "cycleActive", "label": "Cycle active", "address": "DB1,X8.0", "dataType": "boolean" },
        { "name": "cycleCount", "label": "Cycle count", "address": "DB1,INT10", "dataType": "number" },
        { "name": "runCmd", "label": "Run command", "address": "DB1,X12.0", "dataType": "boolean", "writable": true },
        { "name": "targetPressure", "label": "Target pressure", "address": "DB1,REAL14", "dataType": "number", "unit": "bar", "writable": true }
      ]
    }
  ],
  "links": [
    { "from": "tia.Motor", "to": "conv.motorCmd" },
    { "from": "tia.Conveyor_PWM", "to": "conv.speedCmd" },
    { "from": "conv.photoEye", "to": "tia.Part_Sensor" }
  ]
}
